+                    $row['date'],
+                    $row['reference'],
+                    $row['description'],
+                    number_format($row['debit'], 4, '.', ''),
+                    number_format($row['credit'], 4, '.', ''),
+                    number_format($row['running_balance'], 4, '.', ''),
+                ];
+            }
+        }
+
+        return $rows;
+    }
 }
