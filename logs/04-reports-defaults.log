diff --git a/modules/DoubleEntry/Http/Controllers/Concerns/ExportsCsv.php b/modules/DoubleEntry/Http/Controllers/Concerns/ExportsCsv.php
new file mode 100644
index 0000000000000000000000000000000000000000..978b084d961473640647be9f8df5be7fa52d0323
--- /dev/null
+++ b/modules/DoubleEntry/Http/Controllers/Concerns/ExportsCsv.php
@@ -0,0 +1,25 @@
+<?php
+
+namespace Modules\DoubleEntry\Http\Controllers\Concerns;
+
+trait ExportsCsv
+{
+    protected function streamCsv(string $reportName, array $headings, array $rows, ?string $date = null)
+    {
+        $filename = sprintf('%s-%s.csv', $reportName, $date ?: now()->toDateString());
+
+        return response()->stream(function () use ($headings, $rows): void {
+            $handle = fopen('php://output', 'w');
+            fputcsv($handle, $headings);
+
+            foreach ($rows as $row) {
+                fputcsv($handle, $row);
+            }
+
+            fclose($handle);
+        }, 200, [
+            'Content-Type' => 'text/csv',
+            'Content-Disposition' => 'attachment; filename="' . $filename . '"',
+        ]);
+    }
+}
