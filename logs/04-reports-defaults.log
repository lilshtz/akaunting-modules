+                    'company_id' => company_id(),
+                    'type' => $defaultType,
+                ],
+                [
+                    'account_id' => $account->id,
+                ]
+            );
+        }
+
+        flash(trans('messages.success.updated', ['type' => trans('double-entry::general.account_defaults')]))->success();
+
         return redirect()->route('double-entry.account-defaults.index');
