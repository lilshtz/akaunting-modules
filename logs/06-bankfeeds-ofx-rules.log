+    protected function detectFormat(string $filename): string
+    {
+        $extension = strtolower((string) pathinfo($filename, PATHINFO_EXTENSION));
+
+        return match ($extension) {
+            'ofx' => 'ofx',
+            'qfx' => 'qfx',
+            default => 'csv',
+        };
