+        }
+
+        $transactions = DB::transaction(function () use ($import, $rows): Collection {
+            Transaction::query()
+                ->byCompany()
+                ->where('import_id', $import->id)
+                ->delete();
+
+            $transactions = new Collection();
+
+            foreach ($rows as $row) {
+                $hash = hash('sha256', $row['date'] . '|' . $row['amount'] . '|' . $row['description']);
