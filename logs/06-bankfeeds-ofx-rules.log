+                    'type' => $row['type'],
+                    'raw_data_json' => $row['raw_data_json'] ?? $row,
+                    'status' => 'pending',
+                    'duplicate_hash' => $hash,
+                    'is_duplicate' => $duplicateExists,
+                ]));
+            }
+
+            return $transactions;
+        });
+
+        $categorizedCount = $this->ruleEngine->applyRules($transactions, company_id());
+
+        $import->update([
+            'row_count' => count($rows),
+            'status' => 'complete',
+            'imported_at' => now(),
+            'error_message' => null,
+        ]);
+
+        if ($categorizedCount > 0) {
+            flash(trans('bank-feeds::general.messages.rules_auto_applied', ['count' => $categorizedCount]))->info();
+        }
+
+        return $transactions;
+    }
 }
