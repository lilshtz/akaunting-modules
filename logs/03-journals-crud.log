+        $companyId ??= company_id();
+
+        $maxReference = static::query()
+            ->byCompany($companyId)
+            ->withTrashed()
+            ->where('reference', 'like', 'JE-%')
+            ->lockForUpdate()
+            ->selectRaw('MAX(CAST(SUBSTRING(reference, 4) AS UNSIGNED)) as max_reference')
+            ->value('max_reference');
+
+        return 'JE-' . str_pad((string) (((int) $maxReference) + 1), 4, '0', STR_PAD_LEFT);
     }
 }
