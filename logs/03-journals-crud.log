+                    <div class="text-xs font-semibold uppercase tracking-wide">{{ trans('double-entry::general.status') }}</div>
+                    <div id="balance-status" class="mt-2 text-lg font-semibold">{{ trans('double-entry::general.unbalanced') }}</div>
+                </div>
+            </div>
+        </div>
