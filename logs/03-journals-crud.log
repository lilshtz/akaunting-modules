+    {
+        $lines = $this->relationLoaded('lines') ? $this->lines : $this->lines()->get(['debit', 'credit']);
+        $debit = round((float) $lines->sum('debit'), 4);
+        $credit = round((float) $lines->sum('credit'), 4);
