+use Illuminate\Support\Facades\DB;
+use Modules\DoubleEntry\Services\AccountBalanceService;
 
 class Account extends Model
 {
+    use SoftDeletes;
+
     protected $table = 'double_entry_accounts';
 
     protected $fillable = [
@@ -22,7 +28,7 @@
