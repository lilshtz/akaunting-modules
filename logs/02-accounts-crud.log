diff --git a/modules/DoubleEntry/Http/Requests/AccountStore.php b/modules/DoubleEntry/Http/Requests/AccountStore.php
new file mode 100644
index 0000000000000000000000000000000000000000..d59ad4ca24c062549056e555979d92567ca14c43
