+            'liability' => 2000,
+            'equity' => 3000,
+            'income' => 4000,
+            'expense' => 5000,
+        ];
+
+        $start = $ranges[$type] ?? 9000;
+        $latestCode = Account::query()
+            ->byCompany()
+            ->where('type', $type)
+            ->whereRaw('code REGEXP "^[0-9]+$"')
+            ->selectRaw('MAX(CAST(code AS UNSIGNED)) as max_code')
+            ->value('max_code');
+
+        $next = $latestCode ? ((int) $latestCode + 10) : $start;
+
+        return (string) $next;
