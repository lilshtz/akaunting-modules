+        if (! $handle) {
+            flash(trans('double-entry::general.messages.import_failed'))->error();
+
+            return redirect()->back();
+        }
+
+        $header = fgetcsv($handle);
+
+        if (! $header) {
+            fclose($handle);
+            flash(trans('double-entry::general.messages.import_failed'))->error();
+
+            return redirect()->back();
